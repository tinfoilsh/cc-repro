# Gemma-4-31B — single-GPU dense arm (TP=1).
# Isolates the per-token data-path + CPU-TEE + kernel-launch tax with ZERO
# cross-GPU communication — i.e. the single-GPU overhead in isolation.
#
#   source presets/gemma-4-31b.env
#
# This is a gated HuggingFace repo — ensure your HF account/token has access.
#
# ⚠ DEFAULT = NO speculative decoding — the config that runs on the pinned vLLM
#   0.21.0 image. Enabling spec decoding is a DIFFERENT (lower-overhead) measurement:
#   it requires vLLM 0.22.0 + the MTP assistant model, and on the 0.21.0 pin
#   --speculative-config is silently a NO-OP. See the spec block below and the README.
export MODEL="${MODEL:-google/gemma-4-31B-it}"
export MODEL_REVISION="${MODEL_REVISION:-fb9ae262347c3945692f09a612f8bb189def854f}"

export SERVED_NAME=gemma4
export TP=1
export MAX_NUM_SEQS=64
export GPU_MEM_UTIL=0.90
export EXTRA_VLLM_ARGS=""

# To run the spec-decoding-ON configuration you must (a) build the image with vLLM
# 0.22.0 (the 0.21.0 pin makes this a silent no-op) AND (b) fetch the MTP assistant
# repo. Then uncomment:
# export EXTRA_VLLM_ARGS='--speculative-config {"method":"mtp","model":"google/gemma-4-31B-it-assistant","num_speculative_tokens":4}'

export PROMPT_TOKENS=1024
export OUTPUT_TOKENS=256
export CONCS="1 4 16 64 128"
export MAX_SECONDS=75
export SEED=7
