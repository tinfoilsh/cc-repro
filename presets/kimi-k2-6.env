# Kimi K2.6 NVFP4 — multi-GPU MoE arm (TP=8 + expert parallel).
# A large NVFP4 mixture-of-experts model: exercises the per-token cross-GPU
# collective path, which is where confidential-computing overhead is largest.
#
#   source presets/kimi-k2-6.env
#
# vLLM 0.21.0 is REQUIRED: 0.22.x ships a broken nvidia-cutlass-dsl that
# ICE-crashes CUDA-graph capture for every NVFP4 MoE kernel path, so it cannot
# serve this model. The Dockerfile pins it.
#
# A publicly published NVFP4 checkpoint; ships the NVFP4 weights + the tokenizer
# (loaded with trust_remote_code).
export MODEL="${MODEL:-nvidia/Kimi-K2.6-NVFP4}"
# export MODEL_REVISION=<commit-sha>      # optional: pin an exact revision

export SERVED_NAME=kimi
export TP=8
export MAX_NUM_SEQS=256
export GPU_MEM_UTIL=0.90
# Production-faithful flags. --disable-custom-all-reduce is set in BOTH arms as a
# fairness control (it is identical on/off, so it cannot create the CC delta;
# remove it from both arms if you want to measure its interaction with CC).
export EXTRA_VLLM_ARGS="--enable-expert-parallel --kv-cache-dtype fp8 --disable-custom-all-reduce"
export VLLM_USE_FLASHINFER_MOE_FP4=1
# This is the reference TP=8 throughput-frontier serving config. (--mm-encoder-tp-mode
# data is intentionally not passed — it is not part of this serving config.)

# Throughput-frontier sweep: one prompt/output shape; concurrency 1 -> 128 traces
# the memory-bound -> compute-bound transition.
export PROMPT_TOKENS=1024
export OUTPUT_TOKENS=256
export CONCS="1 4 16 64 128"
export MAX_SECONDS=75
export SEED=7
